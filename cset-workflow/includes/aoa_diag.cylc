{% if AOA_DIAG %}
[scheduling]
    [[graph]]
    P1 = """
    recipe_start => aoa_diag => recipe_finish
    """

{% for plev in AOA_PLEV %}
[runtime]
    [[aoa_diag]]
    script = rose task-run -v --app-key=run_cset_recipe
    execution time limit = PT60M
        [[[environment]]]
        CSET_RECIPE_NAME = "ageofair_plot.yaml"
        CSET_ADDOPTS = "--AOA_PLEV={{plev}} --AOA_INCW={{AOA_INCW}} --AOA_CYCLIC={{AOA_CYCLIC}}"
{% endfor %}
{% endif %}
